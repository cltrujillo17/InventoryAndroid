<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <!-- LOGIN -->
    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.zybooks.cs360projectone.FirstFragment"
        android:label="Login"
        tools:layout="@layout/fragment_first">

        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />

        <!-- NEW: Login -> SMS -->
        <action
            android:id="@+id/action_FirstFragment_to_smsFragment"
            app:destination="@id/smsFragment" />
    </fragment>

    <!-- DATA GRID -->
    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.zybooks.cs360projectone.SecondFragment"
        android:label="Data Grid"
        tools:layout="@layout/fragment_second">

        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>

    <!-- NEW: SMS PERMISSIONS -->
    <fragment
        android:id="@+id/smsFragment"
        android:name="com.zybooks.cs360projectone.SmsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_sms" />
</navigation>
